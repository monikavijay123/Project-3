import pandas as pd
import numpy as np
from datetime import datetime, timedelta
import random
import os
 
np.random.seed(42)
random.seed(42)
 
NUM_CUSTOMERS = 10000
REFERENCE_DATE = datetime(2024, 3, 1)
 
print("Generating 10,000 customer records with realistic RFM patterns...\n")
 
# ============================================================
# GENERATE CUSTOMERS TABLE
# ============================================================
 
print("Step 1: Generating customers...")
 
subscription_types = ['Basic', 'Standard', 'Premium', 'Enterprise']
regions = ['North', 'South', 'East', 'West', 'Central']
 
customers = []
for i in range(NUM_CUSTOMERS):
    customer_id = 1000 + i
    
    # Generate customer profile
    subscription = random.choices(
        ['Basic', 'Standard', 'Premium', 'Enterprise'],
        weights=[40, 35, 20, 5]  # realistic distribution
    )[0]
    
    region = random.choice(regions)
    signup_date = REFERENCE_DATE - timedelta(days=random.randint(30, 1095))  # 1-3 years
    
    customer = {
        'customer_id': customer_id,
        'customer_name': f'Customer_{customer_id}',
        'email': f'cust{customer_id}@company.com',
        'subscription_type': subscription,
        'region': region,
        'signup_date': signup_date.strftime('%Y-%m-%d')
    }
    customers.append(customer)
 
df_customers = pd.DataFrame(customers)
customers_file = 'rfm_data/customers.csv'
os.makedirs('rfm_data', exist_ok=True)
df_customers.to_csv(customers_file, index=False)
print(f"{len(df_customers):,} customers generated → {customers_file}")
 
# ============================================================
# GENERATE TRANSACTIONS TABLE
# ============================================================
 
print("\nStep 2: Generating transactions...")
 
transactions = []
transaction_id = 10000
 
# Create realistic RFM distribution
# 30% inactive (Lost/Hibernating segment)
# 20% at-risk (haven't purchased in 90+ days)
# 50% active (Champions, Loyal, Potential Loyalists, New)
 
for idx, customer in df_customers.iterrows():
    customer_id = customer['customer_id']
    signup_date = pd.to_datetime(customer['signup_date'])
    months_active = (REFERENCE_DATE - signup_date).days // 30
    
    # Determine purchase pattern based on distribution
    rand = random.random()
    
    if rand < 0.30:
        # Lost segment: 0-2 purchases, all old
        num_purchases = random.randint(0, 2)
        date_range = (signup_date, signup_date + timedelta(days=180))
    elif rand < 0.50:
        # At-Risk segment: was active, then stopped (3-5 purchases, last >90 days ago)
        num_purchases = random.randint(3, 5)
        date_range = (signup_date, REFERENCE_DATE - timedelta(days=random.randint(120, 365)))
    elif rand < 0.75:
        # Potential Loyalists: moderate activity
        num_purchases = random.randint(2, 5)
        date_range = (signup_date, REFERENCE_DATE - timedelta(days=random.randint(10, 90)))
    else:
        # Champions/Loyal: frequent, recent purchases
        num_purchases = random.randint(4, 15)
        date_range = (signup_date, REFERENCE_DATE - timedelta(days=random.randint(1, 30)))
    
    # Generate individual transactions
    for j in range(num_purchases):
        days_diff = abs((date_range[1] - date_range[0]).days)
        trans_date = date_range[0] + timedelta(
            days=random.randint(0, days_diff)
)
        # Transaction amount varies by subscription
        if customer['subscription_type'] == 'Enterprise':
            amount = round(random.uniform(500, 5000), 2)
        elif customer['subscription_type'] == 'Premium':
            amount = round(random.uniform(200, 1000), 2)
        elif customer['subscription_type'] == 'Standard':
            amount = round(random.uniform(50, 300), 2)
        else:  # Basic
            amount = round(random.uniform(10, 100), 2)
        
        transaction = {
            'transaction_id': transaction_id,
            'customer_id': customer_id,
            'transaction_date': trans_date.strftime('%Y-%m-%d'),
            'amount': amount
        }
        transactions.append(transaction)
        transaction_id += 1
 
df_transactions = pd.DataFrame(transactions)
transactions_file = 'rfm_data/transactions.csv'
df_transactions.to_csv(transactions_file, index=False)
print(f"{len(df_transactions):,} transactions generated → {transactions_file}")
print(f"   (Average {len(df_transactions)/NUM_CUSTOMERS:.1f} purchases per customer)")
 
# ============================================================
# GENERATE SUPPORT TICKETS TABLE
# ============================================================
 
print("\nStep 3: Generating support tickets...")
 
support_tickets = []
ticket_id = 20000
 
# Not all customers have support tickets
# High-ticket customers likely to have more support interactions
# This will be useful for identifying "At-Risk" (high tickets + low activity)
 
for idx, customer in df_customers.iterrows():
    customer_id = customer['customer_id']
    
    # Determine if customer has support tickets
    # 40% of customers never contact support
    # 60% have 1-10 tickets
    if random.random() < 0.40:
        num_tickets = 0
    else:
        num_tickets = random.randint(1, 10)
    
    # Generate support tickets
    for j in range(num_tickets):
        ticket_date = pd.to_datetime(customer['signup_date']) + timedelta(
            days=random.randint(0, (REFERENCE_DATE - pd.to_datetime(customer['signup_date'])).days)
        )
        
        ticket = {
            'ticket_id': ticket_id,
            'customer_id': customer_id,
            'ticket_date': ticket_date.strftime('%Y-%m-%d')
        }
        support_tickets.append(ticket)
        ticket_id += 1
 
df_support = pd.DataFrame(support_tickets)
support_file = 'rfm_data/support_tickets.csv'
df_support.to_csv(support_file, index=False)
print(f" {len(df_support):,} support tickets generated → {support_file}")
 
# ============================================================
# ANALYSIS REPORT
# ============================================================
 
print("\n" + "="*60)
print(" DATA GENERATION SUMMARY")
print("="*60)
 
print(f"\n CUSTOMERS: {len(df_customers):,}")
print(f"   By Subscription Type:")
for stype in ['Basic', 'Standard', 'Premium', 'Enterprise']:
    count = len(df_customers[df_customers['subscription_type'] == stype])
    pct = count / len(df_customers) * 100
    print(f"     {stype}: {count:,} ({pct:.1f}%)")
 
print(f"\nTRANSACTIONS: {len(df_transactions):,}")
print(f"   Total Revenue: ${df_transactions['amount'].sum():,.2f}")
print(f"   Avg Transaction: ${df_transactions['amount'].mean():.2f}")
print(f"   Avg per Customer: {len(df_transactions)/len(df_customers):.1f} purchases")
 
print(f"\nSUPPORT TICKETS: {len(df_support):,}")
customers_with_tickets = df_support['customer_id'].nunique()
print(f"   Customers with tickets: {customers_with_tickets:,} ({customers_with_tickets/len(df_customers)*100:.1f}%)")
print(f"   Avg tickets per customer: {len(df_support)/len(df_customers):.2f}")
 
print(f"\nINACTIVE CUSTOMERS (potential Lost/At-Risk):")
# Get last transaction date for each customer
last_trans = df_transactions.groupby('customer_id')['transaction_date'].max()
inactive_90 = sum((REFERENCE_DATE - pd.to_datetime(last_trans)).dt.days > 90)
print(f"   No purchase in 90+ days: {inactive_90:,} ({inactive_90/len(df_customers)*100:.1f}%)")
 
print(f"\nREVENUE CONCENTRATION:")
# Calculate revenue per customer
revenue_per_cust = df_transactions.groupby('customer_id')['amount'].sum().reset_index()
revenue_per_cust.columns = ['customer_id', 'total_revenue']
revenue_per_cust = revenue_per_cust.sort_values('total_revenue', ascending=False)
 
top_20pct_count = int(len(revenue_per_cust) * 0.2)
top_20pct_revenue = revenue_per_cust.head(top_20pct_count)['total_revenue'].sum()
total_revenue = revenue_per_cust['total_revenue'].sum()
pct_from_top20 = top_20pct_revenue / total_revenue * 100
 
print(f"   Top 20% customers: {top_20pct_count:,}")
print(f"   Generate: ${top_20pct_revenue:,.2f} ({pct_from_top20:.1f}% of total)")
print(f"   Pareto principle confirmed: {pct_from_top20:.1f}% from 20%")
 
print("\n" + "="*60)
print(" DATA GENERATION COMPLETE!")
print("="*60)
 
print("\n NEXT STEPS:")
print("   1. Open SQL Server Management Studio (SSMS)")
print("   2. Run: rfm_02_create_tables.sql")
print("   3. Run: rfm_03_load_data.sql")
print("   4. Run: rfm_04_analysis.sql")
print("   5. View 6 analysis reports!")
print("="*60)
